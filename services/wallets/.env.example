PORT=4002
DATABASE_URL=postgresql://admin:admin@postgres:5432/wallets
RABBITMQ_URL=amqp://admin:admin@rabbitmq:5672

KEYCLOAK_ISSUER_URL=http://localhost:8080/realms/crash-game
